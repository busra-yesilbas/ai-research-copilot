# =============================================================================
#  AI Research Copilot — Environment Variables
#  Copy this file to .env and fill in your values.
#  .env is git-ignored; NEVER commit secrets.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="AI Research Copilot"
APP_VERSION="0.1.0"
ENVIRONMENT=development         # development | staging | production
DEBUG=false

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                  # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=text                 # text | json

# ── Paths ─────────────────────────────────────────────────────────────────────
DATA_DIR=data
INDEX_DIR=data/index
MODELS_DIR=models

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=64
EMBEDDING_DEVICE=cpu            # cpu | cuda

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Vector Store ─────────────────────────────────────────────────────────────
VECTOR_STORE_BACKEND=faiss      # faiss | sklearn
RETRIEVAL_TOP_K=5

# ── LLM / RAG ─────────────────────────────────────────────────────────────────
LLM_PROVIDER=local              # local | openai | anthropic
LLM_MODEL_NAME=local-extractive

# ── OpenAI (only if LLM_PROVIDER=openai) ─────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Anthropic (only if LLM_PROVIDER=anthropic) ───────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Knowledge Graph (Neo4j — optional) ───────────────────────────────────────
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your_password_here

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
